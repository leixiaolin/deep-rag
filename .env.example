# =============================================================================
# Deep RAG Configuration File
# =============================================================================

# LLM provider, default=google, optional: openai、google、anthropic、custom、......
API_PROVIDER=google

# Tool calling mode, default=function, stronger tool calling capabilities, optional: function、react
TOOL_CALLING_MODE=function

# Temperature, default=0, strongest instruction following ability
TEMPERATURE=0

# Maximum output TOKENS, default=8192
MAX_TOKENS=8192

# Knowledge base path, default=./Knowledge-Base
KNOWLEDGE_BASE_PATH=./Knowledge-Base

# Knowledge base chunks path, default=./Knowledge-Base-Chunks
KNOWLEDGE_BASE_CHUNKS_PATH=./Knowledge-Base-Chunks

# Knowledge base file summary path, default=./Knowledge-Base-File-Summary/summary.txt
KNOWLEDGE_BASE_FILE_SUMMARY=./Knowledge-Base-File-Summary/summary.txt


# =============================================================================
# Retrieval Backend
# =============================================================================

# direct: read explicit files/directories from Knowledge-Base-Chunks
# milvus_hybrid: sparse BM25 + dense vector hybrid retrieval in one Milvus request
RETRIEVAL_BACKEND=direct

MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=root:Milvus
MILVUS_COLLECTION=deep_rag_chunks_v1
MILVUS_DENSE_METRIC_TYPE=COSINE
MILVUS_DENSE_INDEX_TYPE=HNSW
MILVUS_HNSW_M=16
MILVUS_HNSW_EF_CONSTRUCTION=200
MILVUS_HNSW_EF=64
MILVUS_BM25_K1=1.2
MILVUS_BM25_B=0.75
MILVUS_MAX_TEXT_LENGTH=65000

EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT=120

HYBRID_TOP_K=8
HYBRID_MAX_TOP_K=30
HYBRID_RRF_K=100
HYBRID_RANKER=rrf
HYBRID_DENSE_WEIGHT=0.3
HYBRID_SPARSE_WEIGHT=0.7


# =============================================================================
# Cache
# =============================================================================

# memory: local development, no external service required
# redis: production, shared across workers/instances
CACHE_ENABLED=true
CACHE_BACKEND=memory
CACHE_REDIS_URL=redis://localhost:6379/0
CACHE_KEY_PREFIX=deep-rag
CACHE_DEFAULT_TTL_SECONDS=300
CACHE_SUMMARY_TTL_SECONDS=3600
CACHE_FILE_TTL_SECONDS=3600
CACHE_EMBEDDING_TTL_SECONDS=2592000
CACHE_HYBRID_SEARCH_TTL_SECONDS=600
CACHE_MAX_MEMORY_ITEMS=2048
CACHE_LOCK_TTL_SECONDS=30
CACHE_LOCK_WAIT_SECONDS=2

# Required for POST /cache/invalidate. Leave empty to disable the endpoint.
CACHE_ADMIN_TOKEN=


# =============================================================================
# LLM Provider Configuration (All APIs use OpenAI completions format)
# =============================================================================

# OpenAI GPT
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Google Gemini
GOOGLE_API_KEY=your_google_key
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GOOGLE_MODEL=gemini-2.5-flash-lite

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Custom LLM API
CUSTOM_API_KEY=your_api_key
CUSTOM_BASE_URL=https://your-api.com/v1/chat/completions
CUSTOM_MODEL=your-model
CUSTOM_HEADERS={"Authorization":"Bearer token"}


# =============================================================================
# Add New Provider (No code modification needed!)
# =============================================================================
# Just add 3 lines of configuration:
#   PROVIDER_API_KEY=your_key
#   PROVIDER_BASE_URL=https://api.provider.com/v1
#   PROVIDER_MODEL=model-name
# Then set API_PROVIDER=provider
# =============================================================================
